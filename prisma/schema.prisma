// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                    String                 @id @default(uuid()) @map("id")
    name                  String                 @map("name")
    username              String                 @unique @map("username")
    password              String                 @map("password")
    roleId                String
    role                  Role                   @relation(fields: [roleId], references: [id])
    teacher               Teacher?
    mustChangeCredentials Boolean                @default(false)
    userPermissions       UserPermission[]
    userDormitories       UserDormitory[]
    permit                Permit[]
    ScheduleSubstitution  ScheduleSubstitution[]
    SubstitutionBatch     SubstitutionBatch[]

    @@index([roleId])
}

model Role {
    id      String   @id @default(uuid())
    name    String   @unique
    canEdit Boolean? @default(true)

    users           User[]
    rolePermissions RolePermission[]
    roleDormitories RoleDormitory[]
}

model Permission {
    id       String  @id @default(uuid())
    resource String // e.g., "dormitory"
    action   String // e.g., "edit", "view"
    name     String  @unique // e.g., "dormitory:edit"
    label    String?

    rolePermissions RolePermission[]
    userPermissions UserPermission[]
}

model RolePermission {
    roleId       String
    permissionId String     @map("permission_id")
    role         Role       @relation(fields: [roleId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([roleId, permissionId])
}

model UserPermission {
    userId       String
    permissionId String     @map("permission_id")
    allow        Boolean
    user         User       @relation(fields: [userId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([userId, permissionId])
}

model UserDormitory {
    userId      String
    dormitoryId String    @map("dormitory_id")
    user        User      @relation(fields: [userId], references: [id])
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])

    @@id([userId, dormitoryId])
}

model RoleDormitory {
    roleId      String
    dormitoryId String    @map("dormitory_id")
    role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)

    @@id([roleId, dormitoryId])
    @@map("role_dormitory")
}

// ENUMS
enum StudentStatus {
    ACTIVE
    INACTIVE
    TRANSFERRED
}

enum HistoryStatus {
    STUDYING
    GRADUATED
    REPEATED
    TRANSFERRED
}

enum AbsenceStatus {
    PRESENT
    SICK
    PERMIT
    ABSENT
}

enum Permittatus {
    SICK
    PERMIT
}

enum DormitoryStatus {
    ACTIVE
    GRADUATED
    TRANSFERRED
}

enum GenderType {
    PUTRA
    PUTRI
}

// MASTER DATA
model Student {
    id           String   @id @default(uuid())
    nis          String   @unique
    name         String
    placeOfBirth String
    dateOfBirth  DateTime
    address      String?
    fatherName   String?
    motherName   String?
    parrentPhone String?

    gender GenderType? @default(PUTRA)

    dormitoryId String?
    dormitory   Dormitory? @relation(fields: [dormitoryId], references: [id])
    villageId   Int?
    village     Village?   @relation(fields: [villageId], references: [id])
    districtId  Int?
    district    District?  @relation(fields: [districtId], references: [id])
    regencyId   Int?
    regency     Regency?   @relation(fields: [regencyId], references: [id])
    provinceId  Int?
    province    Province?  @relation(fields: [provinceId], references: [id])

    histories          History[]
    absences           Absence[]
    permits            Permit[]
    dormitoryHistories DormitoryHistory[]

    status StudentStatus? @default(ACTIVE)

    createdAt                 DateTime                    @default(now())
    updatedAt                 DateTime                    @updatedAt
    testRegistration          TestRegistration[]
    formalClass               FormalClass?                @relation(fields: [formalClassId], references: [id])
    formalClassId             String?
    dormitoryRoom             DormitoryRoom?              @relation(fields: [dormitoryRoomId], references: [id])
    dormitoryRoomId           String?
    positionHistoryLeadership PositionHistoryLeadership[]
    Response                  Response[]

    @@index([name]) // <-- TAMBAHKAN: Untuk pencarian berdasarkan nama
    @@index([dormitoryId]) // <-- TAMBAHKAN: Untuk filter santri per asrama
    @@index([status]) // <-- TAMBAHKAN: Untuk filter santri berdasarkan status (misal: semua yg aktif)
    @@index([formalClassId]) // <-- TAMBAHKAN: Untuk filter santri per kelas formal
    @@index([dormitoryRoomId]) // <-- TAMBAHKAN: Untuk filter santri per kamar
    @@index([gender])
    @@index([status, dormitoryId])
}

enum PositionRole {
    CHAIRMAN
    MEMBER
}

model Leadership {
    id          String  @id @default(uuid())
    name        String  @unique
    description String?

    positionHistories PositionHistoryLeadership[]
}

model TermLeadership {
    id        String   @id @default(uuid())
    name      String   @unique // e.g., "2024-2025"
    startDate DateTime
    endDate   DateTime

    positionHistories PositionHistoryLeadership[]
}

model PositionHistoryLeadership {
    id    String       @id @default(uuid())
    role  PositionRole @default(MEMBER)
    notes String?

    studentId String
    student   Student @relation(fields: [studentId], references: [id])

    leadershipId String
    leadership   Leadership @relation(fields: [leadershipId], references: [id])

    termLeadershipId String
    termLeadership   TermLeadership @relation(fields: [termLeadershipId], references: [id])

    createdAt DateTime @default(now())
}

model FormalClass {
    id      String    @id @default(uuid())
    name    String    @unique
    Student Student[]
}

model Teacher {
    id                 String                @id @default(uuid())
    name               String
    subjects           TeacherSubjectClass[]
    schedules          Schedule[]
    absences           TeacherAbsence[]
    createdAt          DateTime              @default(now())
    updatedAt          DateTime              @updatedAt
    absence            Absence[]
    teacherDormitories TeacherDormitory[]

    phoneWhatsapp String? @unique

    userId               String                 @unique
    user                 User                   @relation(fields: [userId], references: [id])
    substitutedSchedules ScheduleSubstitution[] @relation("SubstituteTeacher")

    @@index([name])
}

model Dormitory {
    id               String             @id @default(uuid())
    name             String
    level            Int
    students         Student[]
    classes          Class[]
    userDormitories  UserDormitory[]
    roleDormitories  RoleDormitory[]
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    gender           GenderType?        @default(PUTRA)
    dormitoryHistory DormitoryHistory[]
    dormitoryTracks  DormitoryTrack[] // pivot relasi ke track
    teacherDormitory TeacherDormitory[]

    dormitoryRoom     DormitoryRoom[]
    scheduleSlots     ScheduleSlot[]
    SubstitutionBatch SubstitutionBatch[]
}

model DormitoryRoom {
    id          String    @id @default(cuid())
    name        String
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])
    dormitoryId String
    students    Student[]
}

model DormitoryHistory {
    id                 String          @id @default(uuid())
    studentId          String
    dormitoryId        String
    startDate          DateTime
    endDate            DateTime?
    status             DormitoryStatus
    dormNameAtThatTime String

    student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([studentId]) // <-- TAMBAHKAN INI
    @@index([dormitoryId]) // <-- TAMBAHKAN INI
    @@index([studentId, endDate])
}

// AKADEMIK
model Track {
    id              String           @id @default(uuid()) // Fan
    name            String
    targetDays      Int              @default(0)
    classes         Class[]
    subjects        Subject[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    dormitoryTracks DormitoryTrack[] // pivot relasi ke dormitory
    level           Int?             @default(0)

    sks Sks[]
}

model Sks {
    id               String             @id @default(uuid())
    name             String
    Track            Track?             @relation(fields: [trackId], references: [id])
    trackId          String?
    passingGrade     Int?               @default(0)
    testRegistration TestRegistration[]

    sksKey String?

    validFrom DateTime @default(now())
    validTo   DateTime?
    deletedAt DateTime?

    @@index([trackId])
    @@index([trackId, sksKey])
    @@index([trackId, validFrom])
    @@index([trackId, validTo])
    @@index([trackId, deletedAt])
}

model TestRegistration {
    id          String             @id @default(uuid())
    studentId   String
    sksId       String
    scheduledAt DateTime?
    status      RegistrationStatus @default(PENDING)
    createdAt   DateTime           @default(now())

    student   Student  @relation(fields: [studentId], references: [id])
    sks       Sks      @relation(fields: [sksId], references: [id])
    test      Test?
    Subject   Subject? @relation(fields: [subjectId], references: [id])
    subjectId String?

    @@index([studentId]) // <-- TAMBAHKAN
    @@index([sksId]) // <-- TAMBAHKAN
    @@index([status]) // <-- TAMBAHKAN
    @@index([subjectId]) // <-- TAMBAHKAN
}

model Test {
    id             String   @id @default(uuid())
    registrationId String   @unique
    score          Float
    passed         Boolean
    attemptNumber  Int
    createdAt      DateTime @default(now())

    registration TestRegistration @relation(fields: [registrationId], references: [id])
}

enum RegistrationStatus {
    PENDING
    COMPLETED
    CANCELLED
}

model Subject {
    id               String                @id @default(uuid())
    name             String
    trackId          String
    track            Track                 @relation(fields: [trackId], references: [id])
    // histories    History[]
    schedules        Schedule[]
    teacherLinks     TeacherSubjectClass[]
    createdAt        DateTime              @default(now())
    updatedAt        DateTime              @updatedAt
    TestRegistration TestRegistration[]

    @@index([name]) // <-- TAMBAHKAN
    @@index([trackId]) // <-- TAMBAHKAN
}

model TeacherDormitory {
    teacherId   String
    dormitoryId String

    teacher   Teacher   @relation(fields: [teacherId], references: [id])
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])

    @@id([teacherId, dormitoryId])
}

model DormitoryTrack {
    dormitoryId String
    trackId     String

    level     Int       @default(0)
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])
    track     Track     @relation(fields: [trackId], references: [id])
    // @@unique([dormitoryId, level])

    @@id([dormitoryId, trackId])
}

model Class {
    id          String @id @default(uuid())
    name        String // e.g., "Ubudiyah - Ust Umam"
    teacher     String // Wali kelas
    trackId     String
    dormitoryId String

    track     Track     @relation(fields: [trackId], references: [id])
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])

    active Boolean? @default(true)

    histories    History[]
    schedules    Schedule[]
    teacherLinks TeacherSubjectClass[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([trackId]) // <-- TAMBAHKAN
    @@index([dormitoryId]) // <-- TAMBAHKAN
    @@index([active]) // <-- TAMBAHKAN
}

model TeacherSubjectClass {
    id        String @id @default(uuid())
    teacherId String
    subjectId String
    classId   String

    teacher Teacher @relation(fields: [teacherId], references: [id])
    subject Subject @relation(fields: [subjectId], references: [id])
    class   Class   @relation(fields: [classId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model History {
    id        String        @id @default(uuid())
    studentId String
    classId   String
    // subjectId String
    startDate DateTime      @default(now())
    endDate   DateTime?
    status    HistoryStatus
    score     Int?

    classNameAtThatTime    String?
    classTeacherAtThatTime String?
    dormNameAtThatTime     String?
    trackNameAtThatTime    String?

    student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
    class   Class   @relation(fields: [classId], references: [id])
    // subject Subject @relation(fields: [subjectId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([classId, status, studentId])
    @@index([classId, startDate, endDate])
    @@index([studentId]) // <-- TAMBAHKAN INI
    @@index([studentId, status, endDate])
}

// JADWAL
model ScheduleSlot {
    id        String @id @default(uuid())
    slot      Int // Jam ke-n
    startTime String // ex: "07:00"
    endTime   String

    dormitoryId String
    dormitory   Dormitory  @relation(fields: [dormitoryId], references: [id])
    schedules   Schedule[]

    createdAt            DateTime               @default(now())
    updatedAt            DateTime               @updatedAt
    ScheduleSubstitution ScheduleSubstitution[]
}

// HEADER aksi massal (audit & rollback)
model SubstitutionBatch {
    id      String  @id @default(uuid())
    dateKey String  @db.VarChar(10) // "YYYY-MM-DD" Asia/Jakarta
    scope   String // "SINGLE" | "SLOT_SELECTED" | "SLOT_ALL"
    reason  String?

    // konteks opsional
    dormitoryId String?
    dormitory   Dormitory? @relation(fields: [dormitoryId], references: [id])

    dayOfWeek   Int?
    createdById String?
    createdBy   User?   @relation(fields: [createdById], references: [id])

    createdAt DateTime @default(now())

    // RELASI balik ke detail
    substitutions ScheduleSubstitution[] // <— penting untuk audit/rollback

    @@index([dateKey])
    @@index([createdAt])
}

model ScheduleSubstitution {
    id String @id @default(uuid())

    // jadwal spesifik yang dioverride (kelas, mapel, versi validFrom/validTo)
    scheduleId String
    schedule   Schedule @relation(fields: [scheduleId], references: [id])

    // slot yang dipakai pada hari itu (buat filter cepat & konsisten)
    scheduleSlotId String
    scheduleSlot   ScheduleSlot @relation(fields: [scheduleSlotId], references: [id])

    // tanggal pelaksanaan override
    date    DateTime // simpan 00:00:00 Asia/Jakarta
    dateKey String   @db.VarChar(10) // "YYYY-MM-DD" utk query/index harian

    // guru pengganti
    substituteId String
    substitute   Teacher @relation("SubstituteTeacher", fields: [substituteId], references: [id])

    // metadata opsional
    reason      String?
    createdById String?
    createdBy   User?   @relation(fields: [createdById], references: [id])

    // snapshot slot (histori tetap benar bila jam slot berubah di masa depan)
    slotNumber    Int?
    slotStartTime String? // "HH:mm"
    slotEndTime   String? // "HH:mm"

    // GROUPING
    batchId      String?
    batch        SubstitutionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
    mergeGroupId String? // cukup string; jadikan model sendiri jika perlu constraint

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // 1 schedule hanya boleh punya 1 pengganti pada tanggal tsb
    @@unique([scheduleId, dateKey])
    // index untuk pola login: per tanggal + per slot + guru pengganti
    @@index([dateKey])
    @@index([dateKey, scheduleSlotId])
    @@index([substituteId, dateKey, scheduleSlotId])
    @@index([batchId])
    @@index([mergeGroupId])
}

model Schedule {
    id             String @id @default(uuid())
    classId        String
    subjectId      String
    teacherId      String
    scheduleSlotId String
    dayOfWeek      Int // 1 = Senin, ..., 7 = Ahad

    class        Class        @relation(fields: [classId], references: [id])
    subject      Subject      @relation(fields: [subjectId], references: [id])
    teacher      Teacher      @relation(fields: [teacherId], references: [id])
    scheduleSlot ScheduleSlot @relation(fields: [scheduleSlotId], references: [id])

    absences Absence[]

    active    Boolean   @default(true)
    validFrom DateTime  @default(now())
    validTo   DateTime?

    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
    teacherAbsence TeacherAbsence[]

    substitutions ScheduleSubstitution[]

    @@index([classId, dayOfWeek])
    @@index([teacherId, dayOfWeek])
    @@index([teacherId, dayOfWeek, scheduleSlotId, validFrom, validTo])
    @@index([classId, dayOfWeek, scheduleSlotId, validFrom, validTo])
    @@index([dayOfWeek, scheduleSlotId, active, validFrom, validTo])
}

// ABSENSI SANTRI
model Absence {
    id             String        @id @default(uuid())
    studentId      String
    scheduleId     String
    date           DateTime
    absentDate     String        @default("")
    status         AbsenceStatus
    autoFromPermit Boolean       @default(false)
    note           String?

    filledByTeacherId String? // Guru yang melakukan absensi
    filledByTeacher   Teacher? @relation(fields: [filledByTeacherId], references: [id])

    student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
    schedule Schedule @relation(fields: [scheduleId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([studentId, scheduleId, absentDate])
    @@index([absentDate]) // <-- TAMBAHKAN
    @@index([scheduleId]) // <-- TAMBAHKAN
}

// PERIZINAN SANTRI
model Permit {
    id              String      @id @default(uuid())
    studentId       String
    startDate       DateTime
    endDate         DateTime?
    allowedSlots    Int[] // Contoh: [1, 3, 5]
    reason          String
    permitSTatus    Permittatus
    student         Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
    createdByUserId String
    createdBy       User        @relation(fields: [createdByUserId], references: [id])

    @@index([studentId]) // <-- TAMBAHKAN
    @@index([startDate, endDate]) // <-- TAMBAHKAN
}

// ABSENSI GURU PER HARI
model TeacherAbsence {
    id         String        @id @default(uuid())
    teacherId  String
    scheduleId String
    date       DateTime
    dateKey    String        @db.VarChar(10)
    status     AbsenceStatus
    note       String?

    teacher   Teacher  @relation(fields: [teacherId], references: [id])
    schedule  Schedule @relation(fields: [scheduleId], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([teacherId, scheduleId, date])
    @@unique([teacherId, scheduleId, dateKey])
    @@index([teacherId, date])
    @@index(teacherId)
    @@index([scheduleId])
}

model Province {
    id   Int    @id @default(autoincrement())
    name String
    code String

    regencies Regency[]
    Student   Student[]

    @@index([name])
}

model Regency {
    id        Int        @id @default(autoincrement())
    name      String
    label     String?
    type      String?
    code      String
    fullCode  String
    districts District[]

    provinceId Int
    province   Province  @relation(fields: [provinceId], references: [id])
    Student    Student[]

    @@index([provinceId])
    @@index([name])
    @@index([label])
}

model District {
    id       Int       @id @default(autoincrement())
    name     String
    code     String
    fullCode String
    villages Village[]

    regencyId Int
    regency   Regency   @relation(fields: [regencyId], references: [id])
    Student   Student[]

    @@index([regencyId])
    @@index([name])
}

model Village {
    id         Int    @id @default(autoincrement())
    name       String
    code       String
    fullCode   String
    postalCode String

    districtId Int
    district   District  @relation(fields: [districtId], references: [id])
    students   Student[]

    @@index([districtId])
    @@index([name])
}

model Recipient {
    id       String  @id @default(uuid())
    name     String
    isActive Boolean @default(true)

    // Telegram
    enableTelegram Boolean @default(false)
    telegramChatId String? @unique

    // WhatsApp
    enableWhatsApp Boolean @default(false)
    whatsappPhone  String? @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Period {
    id       String    @id @default(cuid())
    name     String
    startsAt DateTime?
    endsAt   DateTime?
    isActive Boolean   @default(false)
    template Json // {version, title, fields: FieldDef[]}

    responses Response[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isActive])
}

model Response {
    id       String @id @default(cuid())
    periodId String
    period   Period @relation(fields: [periodId], references: [id])

    studentId String?
    student   Student? @relation(fields: [studentId], references: [id])

    answers  Json // payload dinamis sesuai template
    avgScore Float? // ringkasan (rating_5) - file/text tidak dihitung
    nps      Int? // 0..10 (opsional)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([periodId])
    @@index([studentId])
}
