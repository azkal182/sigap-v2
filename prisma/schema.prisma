// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider        = "prisma-client-js"
    output          = "../src/generated/prisma"
    previewFeatures = ["metrics"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_DATABASE_URL")
}

model User {
    id                    String           @id @default(uuid()) @map("id")
    name                  String           @map("name")
    username              String           @unique @map("username")
    password              String           @map("password")
    roleId                String
    role                  Role             @relation(fields: [roleId], references: [id])
    teacher               Teacher?
    mustChangeCredentials Boolean          @default(false)
    userPermissions       UserPermission[]
    userDormitories       UserDormitory[]
}

model Role {
    id      String   @id @default(uuid())
    name    String   @unique
    canEdit Boolean? @default(true)

    users           User[]
    rolePermissions RolePermission[]
    roleDormitories RoleDormitory[]
}

model Permission {
    id       String  @id @default(uuid())
    resource String // e.g., "dormitory"
    action   String // e.g., "edit", "view"
    name     String  @unique // e.g., "dormitory:edit"
    label    String?

    rolePermissions RolePermission[]
    userPermissions UserPermission[]
}

model RolePermission {
    roleId       String
    permissionId String     @map("permission_id")
    role         Role       @relation(fields: [roleId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([roleId, permissionId])
}

model UserPermission {
    userId       String
    permissionId String     @map("permission_id")
    allow        Boolean
    user         User       @relation(fields: [userId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([userId, permissionId])
}

model UserDormitory {
    userId      String
    dormitoryId String    @map("dormitory_id")
    user        User      @relation(fields: [userId], references: [id])
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])

    @@id([userId, dormitoryId])
}

model RoleDormitory {
    roleId      String
    dormitoryId String    @map("dormitory_id")
    role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)

    @@id([roleId, dormitoryId])
    @@map("role_dormitory")
}

// ENUMS
enum StudentStatus {
    ACTIVE
    INACTIVE
    TRANSFERRED
}

enum HistoryStatus {
    STUDYING
    GRADUATED
    REPEATED
    TRANSFERRED
}

enum AbsenceStatus {
    PRESENT
    SICK
    PERMIT
    ABSENT
}

enum DormitoryStatus {
    ACTIVE
    GRADUATED
    TRANSFERRED
}

// MASTER DATA
model Student {
    id           String   @id @default(uuid())
    nis          String   @unique
    name         String
    placeOfBirth String
    dateOfBirth  DateTime
    address      String?
    fatherName   String?
    motherName   String?
    parrentPhone String?

    dormitoryId String
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])
    villageId   Int?
    village     Village?  @relation(fields: [villageId], references: [id])

    histories          History[]
    absences           Absence[]
    permits            Permit[]
    dormitoryHistories DormitoryHistory[]

    status StudentStatus? @default(ACTIVE)

    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    testRegistration TestRegistration[]
    formalClass      FormalClass?       @relation(fields: [formalClassId], references: [id])
    formalClassId    String?
    dormitoryRoom    DormitoryRoom?     @relation(fields: [dormitoryRoomId], references: [id])
    dormitoryRoomId  String?
}

model FormalClass {
    id      String    @id @default(uuid())
    name    String    @unique
    Student Student[]
}

model Teacher {
    id                 String                @id @default(uuid())
    name               String
    subjects           TeacherSubjectClass[]
    schedules          Schedule[]
    absences           TeacherAbsence[]
    createdAt          DateTime              @default(now())
    updatedAt          DateTime              @updatedAt
    absence            Absence[]
    teacherDormitories TeacherDormitory[]

    userId String @unique
    user   User   @relation(fields: [userId], references: [id])
}

model Dormitory {
    id               String             @id @default(uuid())
    name             String
    level            Int
    students         Student[]
    classes          Class[]
    userDormitories  UserDormitory[]
    roleDormitories  RoleDormitory[]
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    dormitoryHistory DormitoryHistory[]
    dormitoryTracks  DormitoryTrack[] // pivot relasi ke track
    teacherDormitory TeacherDormitory[]

    dormitoryRoom DormitoryRoom[]
    scheduleSlots ScheduleSlot[]
}

model DormitoryRoom {
    id          String    @id @default(cuid())
    name        String
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])
    dormitoryId String
    students    Student[]
}

model DormitoryHistory {
    id                 String          @id @default(uuid())
    studentId          String
    dormitoryId        String
    startDate          DateTime
    endDate            DateTime?
    status             DormitoryStatus
    dormNameAtThatTime String

    student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// AKADEMIK
model Track {
    id              String           @id @default(uuid()) // Fan
    name            String
    targetDays      Int              @default(0)
    classes         Class[]
    subjects        Subject[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    dormitoryTracks DormitoryTrack[] // pivot relasi ke dormitory
    level           Int?             @default(0)

    sks Sks[]
}

model Sks {
    id               String             @id @default(uuid())
    name             String
    Track            Track?             @relation(fields: [trackId], references: [id])
    trackId          String?
    passingGrade     Int?               @default(0)
    testRegistration TestRegistration[]
}

model TestRegistration {
    id          String             @id @default(uuid())
    studentId   String
    sksId       String
    scheduledAt DateTime?
    status      RegistrationStatus @default(PENDING)
    createdAt   DateTime           @default(now())

    student   Student  @relation(fields: [studentId], references: [id])
    sks       Sks      @relation(fields: [sksId], references: [id])
    test      Test?
    Subject   Subject? @relation(fields: [subjectId], references: [id])
    subjectId String?
}

model Test {
    id             String   @id @default(uuid())
    registrationId String   @unique
    score          Float
    passed         Boolean
    attemptNumber  Int
    createdAt      DateTime @default(now())

    registration TestRegistration @relation(fields: [registrationId], references: [id])
}

enum RegistrationStatus {
    PENDING
    COMPLETED
    CANCELLED
}

model Subject {
    id               String                @id @default(uuid())
    name             String
    trackId          String
    track            Track                 @relation(fields: [trackId], references: [id])
    // histories    History[]
    schedules        Schedule[]
    teacherLinks     TeacherSubjectClass[]
    createdAt        DateTime              @default(now())
    updatedAt        DateTime              @updatedAt
    TestRegistration TestRegistration[]
}

model TeacherDormitory {
    teacherId   String
    dormitoryId String

    teacher   Teacher   @relation(fields: [teacherId], references: [id])
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])

    @@id([teacherId, dormitoryId])
}

model DormitoryTrack {
    dormitoryId String
    trackId     String

    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])
    track     Track     @relation(fields: [trackId], references: [id])

    @@id([dormitoryId, trackId])
}

model Class {
    id          String @id @default(uuid())
    name        String // e.g., "Ubudiyah - Ust Umam"
    teacher     String // Wali kelas
    trackId     String
    dormitoryId String

    track     Track     @relation(fields: [trackId], references: [id])
    dormitory Dormitory @relation(fields: [dormitoryId], references: [id])

    active Boolean? @default(true)

    histories    History[]
    schedules    Schedule[]
    teacherLinks TeacherSubjectClass[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model TeacherSubjectClass {
    id        String @id @default(uuid())
    teacherId String
    subjectId String
    classId   String

    teacher Teacher @relation(fields: [teacherId], references: [id])
    subject Subject @relation(fields: [subjectId], references: [id])
    class   Class   @relation(fields: [classId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model History {
    id        String        @id @default(uuid())
    studentId String
    classId   String
    // subjectId String
    startDate DateTime      @default(now())
    endDate   DateTime?
    status    HistoryStatus
    score     Int?

    classNameAtThatTime    String?
    classTeacherAtThatTime String?
    dormNameAtThatTime     String?
    trackNameAtThatTime    String?

    student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
    class   Class   @relation(fields: [classId], references: [id])
    // subject Subject @relation(fields: [subjectId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([classId, status, studentId])
}

// JADWAL
model ScheduleSlot {
    id        String @id @default(uuid())
    slot      Int // Jam ke-n
    startTime String // ex: "07:00"
    endTime   String

    dormitoryId String
    dormitory   Dormitory  @relation(fields: [dormitoryId], references: [id])
    schedules   Schedule[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Schedule {
    id             String @id @default(uuid())
    classId        String
    subjectId      String
    teacherId      String
    scheduleSlotId String
    dayOfWeek      Int // 1 = Senin, ..., 7 = Ahad

    class        Class        @relation(fields: [classId], references: [id])
    subject      Subject      @relation(fields: [subjectId], references: [id])
    teacher      Teacher      @relation(fields: [teacherId], references: [id])
    scheduleSlot ScheduleSlot @relation(fields: [scheduleSlotId], references: [id])

    absences Absence[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// ABSENSI SANTRI
model Absence {
    id             String        @id @default(uuid())
    studentId      String
    scheduleId     String
    date           DateTime
    absentDate     String        @default("")
    status         AbsenceStatus
    autoFromPermit Boolean       @default(false)
    note           String?

    filledByTeacherId String? // Guru yang melakukan absensi
    filledByTeacher   Teacher? @relation(fields: [filledByTeacherId], references: [id])

    student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
    schedule Schedule @relation(fields: [scheduleId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([studentId, scheduleId, absentDate])
}

// PERIZINAN SANTRI
model Permit {
    id           String        @id @default(uuid())
    studentId    String
    startDate    DateTime
    endDate      DateTime
    allowedSlots Int[] // Contoh: [1, 3, 5]
    reason       String
    permitSTatus AbsenceStatus
    student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
}

// ABSENSI GURU PER HARI
model TeacherAbsence {
    id        String        @id @default(uuid())
    teacherId String
    date      DateTime
    status    AbsenceStatus
    note      String?

    teacher   Teacher  @relation(fields: [teacherId], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Province {
    id   Int    @id @default(autoincrement())
    name String
    code String

    regencies Regency[]

    @@index([name])
}

model Regency {
    id        Int        @id @default(autoincrement())
    name      String
    label     String?
    type      String?
    code      String
    fullCode  String
    districts District[]

    provinceId Int
    province   Province @relation(fields: [provinceId], references: [id])

    @@index([provinceId])
    @@index([name])
    @@index([label])
}

model District {
    id       Int       @id @default(autoincrement())
    name     String
    code     String
    fullCode String
    villages Village[]

    regencyId Int
    regency   Regency @relation(fields: [regencyId], references: [id])

    @@index([regencyId])
    @@index([name])
}

model Village {
    id         Int    @id @default(autoincrement())
    name       String
    code       String
    fullCode   String
    postalCode String

    districtId Int
    district   District  @relation(fields: [districtId], references: [id])
    students   Student[]

    @@index([districtId])
    @@index([name])
}

