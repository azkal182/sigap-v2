// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id       String @id @default(uuid()) @map("id")
    name     String @map("name")
    username String @unique @map("username")
    password String @map("password")
    roleId   String
    role     Role   @relation(fields: [roleId], references: [id])

    userPermissions UserPermission[]
    userDormitories UserDormitory[]
}

model Role {
    id   String @id @default(uuid())
    name String @unique

    users           User[]
    rolePermissions RolePermission[]
    roleDormitories RoleDormitory[]
}

model Permission {
    id       String @id @default(uuid())
    resource String // e.g., "dormitory"
    action   String // e.g., "edit", "view"
    name     String @unique // e.g., "dormitory:edit"

    rolePermissions RolePermission[]
    userPermissions UserPermission[]
}

model RolePermission {
    roleId       String
    permissionId String     @map("permission_id")
    role         Role       @relation(fields: [roleId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([roleId, permissionId])
}

model UserPermission {
    userId       String
    permissionId String     @map("permission_id")
    allow        Boolean
    user         User       @relation(fields: [userId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([userId, permissionId])
}

model UserDormitory {
    userId      String
    dormitoryId String    @map("dormitory_id")
    user        User      @relation(fields: [userId], references: [id])
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])

    @@id([userId, dormitoryId])
}

model RoleDormitory {
    roleId      String
    dormitoryId String    @map("dormitory_id")
    role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)

    @@id([roleId, dormitoryId])
    @@map("role_dormitory")
}

model Student {
    id                      String                    @id @default(uuid()) @map("id")
    name                    String                    @map("name")
    nis                     String?                   @map("nis")
    attendance              Attendance[]
    studentGradeHistory     StudentGradeHistory[]
    archiveEmis             ArchiveEmis?              @relation(fields: [archiveEmisId], references: [id])
    archiveEmisId           String?                   @map("archive_emis_id")
    studentFanHistory       StudentFanHistory[]
    studentDormitoryHistory StudentDormitoryHistory[]
    mutationHistories       MutationHistory[]
    fanSubjectAssessment    FanSubjectAssessment[]
    fanProgressTarget       FanProgressTarget[]
    status                  Boolean?                  @default(false)

    @@map("student")
}

model Dormitory {
    id                      String                    @id @default(uuid()) @map("id")
    name                    String                    @map("name")
    level                   Int                       @default(1) @map("level")
    studentGradeHistory     StudentGradeHistory[]
    grade                   Grade[]
    fan                     Fan[]
    studentDormitoryHistory StudentDormitoryHistory[]
    // Relation ke MutationHistory
    fromMutations           MutationHistory[]         @relation("FromDorm")
    toMutations             MutationHistory[]         @relation("ToDorm")

    userDormitories UserDormitory[]
    roleDormitories RoleDormitory[]

    @@map("dormitory")
}

model Grade {
    id                  String                @id @default(uuid()) @map("id")
    name                String                @map("name")
    level               Int                   @default(1) @map("level")
    dormitoryId         String?               @map("dormitory_id")
    dormitory           Dormitory?            @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)
    teachers            GradeTeacher[]
    homeroomTeacherId   String?               @unique @map("homeroom_teacher_id")
    homeroomTeacher     Teacher?              @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
    schedules           Schedule[]
    fan                 Fan?                  @relation(fields: [fanId], references: [id])
    fanId               String?               @map("fan_id")
    studentGradeHistory StudentGradeHistory[]
    fromMutations       MutationHistory[]     @relation("FromGrade")
    toMutations         MutationHistory[]     @relation("ToGrade")

    @@index([dormitoryId])
    @@map("grade")
}

model Teacher {
    id        String           @id @default(uuid()) @map("id")
    name      String           @map("name")
    subjects  TeacherSubject[]
    grades    GradeTeacher[]
    homeroom  Grade?           @relation("HomeroomTeacher")
    schedules Schedule[]

    @@map("teacher")
}

model Subject {
    id        String           @id @default(uuid()) @map("id")
    name      String           @unique @map("name")
    teachers  TeacherSubject[]
    schedules Schedule[]

    @@map("subject")
}

model TeacherSubject {
    teacherId String  @map("teacher_id")
    subjectId String  @map("subject_id")
    teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
    subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

    @@id([teacherId, subjectId])
    @@map("teacher_subject")
}

model GradeTeacher {
    teacherId String  @map("teacher_id")
    gradeId   String  @map("grade_id")
    teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
    grade     Grade   @relation(fields: [gradeId], references: [id], onDelete: Cascade)

    @@id([teacherId, gradeId])
    @@map("grade_teacher")
}

model Schedule {
    id         String       @id @default(uuid()) @map("id")
    period     Int          @map("period")
    dayOfWeek  Int          @map("day_of_week")
    timeStart  String       @map("time_start")
    timeEnd    String       @map("time_end")
    jamKe      Int          @map("jam_ke")
    gradeId    String       @map("grade_id")
    subjectId  String       @map("subject_id")
    teacherId  String       @map("teacher_id")
    teacher    Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
    grade      Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
    subject    Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    attendance Attendance[]

    @@index([gradeId, subjectId, teacherId, dayOfWeek])
    @@map("schedule")
}

model Fan {
    id                String              @id @default(uuid()) @map("id")
    name              String              @map("name")
    level             Int                 @default(1) @map("level")
    dormitoryId       String?             @map("dormitory_id")
    dormitory         Dormitory?          @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)
    grades            Grade[]
    studentFanHistory StudentFanHistory[]
    fromMutations     MutationHistory[]   @relation("FromFan")
    toMutations       MutationHistory[]   @relation("ToFan")
    fanSubject        FanSubject[]
    fanProgressTarget FanProgressTarget[]

    @@unique([name, dormitoryId])
    @@index([dormitoryId])
    @@map("fan")
}

model Attendance {
    id         String   @id @default(uuid()) @map("id")
    date       DateTime @map("date")
    status     String   @map("status")
    studentId  String   @map("student_id")
    student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
    scheduleId String   @map("schedule_id")
    schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
    createdAt  DateTime @default(now()) @map("created_at")

    @@index([studentId, date, scheduleId])
    @@map("attendance")
}

model StudentGradeHistory {
    id          String     @id @default(uuid()) @map("id")
    studentId   String     @map("student_id")
    gradeId     String?    @map("grade_id")
    startDate   DateTime   @map("start_date")
    endDate     DateTime?  @map("end_date")
    student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
    grade       Grade?     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
    dormitory   Dormitory? @relation(fields: [dormitoryId], references: [id])
    dormitoryId String?

    @@index([studentId, gradeId, endDate])
    @@map("student_grade_history")
}

model StudentFanHistory {
    id        String    @id @default(uuid()) @map("id")
    studentId String    @map("student_id")
    fanId     String    @map("fan_id")
    startDate DateTime  @map("start_date")
    endDate   DateTime? @map("end_date")
    student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
    fan       Fan       @relation(fields: [fanId], references: [id], onDelete: Cascade)

    @@index([studentId, fanId, endDate])
    @@map("student_fan_history")
}

model StudentDormitoryHistory {
    id          String    @id @default(uuid()) @map("id")
    studentId   String    @map("student_id")
    dormitoryId String    @map("dormitory_id")
    startDate   DateTime  @map("start_date")
    endDate     DateTime? @map("end_date")
    student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
    dormitory   Dormitory @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)

    @@index([studentId, dormitoryId, startDate])
    @@map("student_dormitory_history")
}

model MutationHistory {
    id              String     @id @default(uuid()) @map("id")
    studentId       String     @map("student_id")
    fromGradeId     String?    @map("from_grade_id")
    toGradeId       String?    @map("to_grade_id")
    fromFanId       String?    @map("from_fan_id")
    toFanId         String?    @map("to_fan_id")
    fromDormitoryId String?    @map("from_dormitory_id")
    toDormitoryId   String?    @map("to_dormitory_id")
    reason          String?    @map("reason")
    date            DateTime   @default(now()) @map("date")
    student         Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
    fromGrade       Grade?     @relation("FromGrade", fields: [fromGradeId], references: [id], onDelete: SetNull)
    toGrade         Grade?     @relation("ToGrade", fields: [toGradeId], references: [id], onDelete: SetNull)
    fromFan         Fan?       @relation("FromFan", fields: [fromFanId], references: [id], onDelete: SetNull)
    toFan           Fan?       @relation("ToFan", fields: [toFanId], references: [id], onDelete: SetNull)
    fromDormitory   Dormitory? @relation("FromDorm", fields: [fromDormitoryId], references: [id], onDelete: SetNull)
    toDormitory     Dormitory? @relation("ToDorm", fields: [toDormitoryId], references: [id], onDelete: SetNull)

    @@index([studentId, date])
    @@map("mutation_history")
}

model FanSubject {
    id          String                 @id @default(uuid()) @map("id")
    fanId       String                 @map("fan_id")
    title       String                 @map("title")
    order       Int                    @map("order")
    fan         Fan                    @relation(fields: [fanId], references: [id], onDelete: Cascade)
    assessments FanSubjectAssessment[]

    @@index([fanId, order])
    @@map("fan_subject")
}

model FanSubjectAssessment {
    id           String     @id @default(uuid()) @map("id")
    studentId    String     @map("student_id")
    fanSubjectId String     @map("fan_subject_id")
    score        Int        @map("score")
    passed       Boolean    @map("passed")
    testedAt     DateTime   @default(now()) @map("tested_at")
    student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
    fanSubject   FanSubject @relation(fields: [fanSubjectId], references: [id], onDelete: Cascade)

    @@index([studentId, fanSubjectId])
    @@map("fan_subject_assessment")
}

model FanProgressTarget {
    id          String    @id @default(uuid()) @map("id")
    studentId   String    @map("student_id")
    fanId       String    @map("fan_id")
    startDate   DateTime  @default(now()) @map("start_date")
    targetEnd   DateTime  @map("target_end")
    completedAt DateTime? @map("completed_at")
    student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
    fan         Fan       @relation(fields: [fanId], references: [id], onDelete: Cascade)

    @@index([studentId, fanId])
    @@map("fan_progress_target")
}

model ArchiveEmis {
    id        String    @id @default(uuid()) @map("id")
    students  Student[]
    kkUrl     String    @map("kk_url")
    ijazahUrl String    @map("ijazah_url")
    createdAt DateTime  @default(now()) @map("created_at")

    @@map("archive_emis")
}
